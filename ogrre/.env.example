# Core environment
ENVIRONMENT=development
COLLABORATOR=isgs
LOCATION=us

# Authentication + authorization
REQUIRE_AUTH=true
AUTH_PROVIDER=google

# CORS (comma-separated list or JSON array)
# Example comma-separated:
ALLOWED_ORIGINS=http://localhost:3000,https://app.example.org
# Example JSON array:
# ALLOWED_ORIGINS=["http://localhost:3000","https://app.example.org"]

# Session cookies
# Leave SESSION_COOKIE_DOMAIN blank for localhost/dev.
# Set to your shared parent domain in production when needed (example: .example.org).
SESSION_COOKIE_DOMAIN=.uow-carbon.org
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_MAX_AGE_SECONDS=3600
REFRESH_COOKIE_MAX_AGE_SECONDS=2592000

# Google OAuth (identity provider)
token_uri=https://oauth2.googleapis.com/token
client_id=
client_secret=

# MongoDB
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_CONNECTION=

# Google Cloud + storage
PROJECT_ID=
STORAGE_SERVICE_KEY=
STORAGE_BUCKET_NAME=

# Storage backend
# Supported values: google, local
STORAGE_BACKEND=google
LOCAL_STORAGE_ROOT=~/.ogrre/uploads
LOCAL_STORAGE_URL_BASE=http://localhost:8001/local-storage

# Document AI backend
# Supported values: google, local
DOCUMENT_AI_BACKEND=google
DOCUMENT_AI_URL=
DOCUMENT_AI_TIMEOUT=60

# Processor schema source
USE_DB_PROCESSORS=true

# Optional app settings
BACKEND_URL=http://localhost:8001
APIKEY=
DETECT_WHITESPACE=true

# Optional diagnostics/performance tuning
MEMORY_PROFILE=false
MEMORY_PROFILE_RATE=1
MEMORY_PROFILE_TOP=10
PROCESS_IMAGE_IN_SUBPROCESS=false
